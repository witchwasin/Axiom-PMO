{
  "disableBypassPermissionsMode": "disable",
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/validate-project.ps1:*)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/pmo-doctor.ps1:*)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/run-validation-tests.ps1:*)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/run-all-checks.ps1:*)",
      "Bash(powershell -ExecutionPolicy Bypass -File scripts/measure-context.ps1:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(gh release:*)",
      "Bash(gh repo:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.pfx)",
      "Write(**/*.p12)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Bash(type .env:*)",
      "Bash(cat .env:*)"
    ]
  }
}
