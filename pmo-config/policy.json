{
  "version": "0.5.1",
  "schema_version": "1.0",
  "sentinel_rules": {
    "not_required": {
      "allowed_fields": ["Design Ref"],
      "allowed_modes": ["Lite"]
    }
  },
  "approval_roles": {
    "Scope Approved": ["Product Owner", "Project Owner"],
    "Design Ready": ["Tech Lead", "Solution Architect"],
    "Release Approved": ["Product Owner", "Release Manager"],
    "QA Approved": ["QA Lead"],
    "Security Approved": ["Security Reviewer", "Tech Lead"]
  },
  "workflow": {
    "canonical_flow": [
      "source",
      "requirement",
      "design",
      "delivery",
      "build_review",
      "qa",
      "release"
    ]
  },
  "enums": {
    "modes": ["Lite", "Standard", "Strict"],
    "gates": ["Draft", "Scope", "Design", "Release"],
    "statuses": ["To Do", "In Progress", "Review / Test", "Done"],
    "review_stages": ["none", "code", "qa", "business", "security"],
    "evidence_statuses": ["verified", "supported", "inferred", "missing", "conflict"],
    "approval_statuses": ["pending", "approved", "rejected"],
    "approval_gates": ["Scope Approved", "Design Ready", "Release Approved"],
    "task_sources": ["file", "github"],
    "strict_triggers": [
      "payment",
      "financial_calculation",
      "pii",
      "sensitive_data",
      "authentication",
      "authorization",
      "permission",
      "irreversible_action",
      "external_integration",
      "legal_compliance",
      "production_data_migration",
      "critical_infrastructure",
      "public_sector_formal_acceptance"
    ],
    "source_ref_patterns": [
      "MOM-\\d{8}",
      "REQ-\\d{8}",
      "REQ-V\\d+",
      "TR-\\d{8}",
      "DEC-\\d{3}",
      "ISSUE-\\d+",
      "PR-\\d+",
      "source_ref"
    ]
  },
  "rollback_waiver": {
    "allowed_modes": ["Lite"],
    "allowed_change_types": ["content-only", "documentation-only", "config-only"]
  },
  "test_waiver": {
    "allowed_modes": ["Standard"],
    "allowed_change_types": ["content-only", "documentation-only", "config-only"]
  },
  "table_schemas": {
    "approval_table": {
      "columns": ["Gate", "Approval Status", "Approver", "Role", "Date", "Evidence"]
    },
    "release_scope": {
      "columns": ["Deliverable", "Requirement Ref", "Included?", "Notes"]
    },
    "qa_security_review": {
      "columns": ["Review Type", "Status", "Reviewer", "Role", "Date", "Evidence"]
    },
    "delivery_work_items": {
      "columns": [
        "ID",
        "Mode",
        "Strict Trigger",
        "Mode Reason",
        "Mode Approved By",
        "Feature / Deliverable",
        "Requirement Ref",
        "Design Ref",
        "Acceptance Criteria",
        "Test Checklist",
        "Owner",
        "Priority",
        "Status",
        "Review Stage",
        "Evidence Ref",
        "Labels"
      ]
    }
  },
  "permissions": {
    "git_mutation_requires_human_confirmation": ["commit", "push", "tag"],
    "production_release_requires_human_confirmation": true,
    "sensitive_paths": [".env", ".env.*", "*.pem", "*.key", "*.pfx", "*.p12", "id_rsa", "id_ed25519"]
  }
}
